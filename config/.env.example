# =============================================================================
# Hermes Agent 环境变量配置模板
# =============================================================================
# 使用方法：
#   1. 复制此文件为 .env：  cp .env.example .env
#   2. 编辑 .env 填入你的 API Key 和配置
#   3. 运行：hermes setup
# =============================================================================

# ── LLM 主 Provider（选择一个）──

# OpenRouter（推荐，一个 Key 访问所有模型）
# 获取 Key：https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# 或者直接用 LongCat
CUSTOM_LONGCAT_API_KEY=your_longcat_api_key_here
CUSTOM_LONGCAT_BASE_URL=https://api.longcat.chat/openai

# 或者 Qwen/Coding
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_BASE_URL=https://coding.dashscope.aliyuncs.com/apps/anthropic

# ── 终端配置 ──
TERMINAL_TIMEOUT=60
TERMINAL_LIFETIME_SECONDS=300

# ── 飞书配置 ──
# 在飞书开放平台创建应用获取：https://open.feishu.cn/
FEISHU_APP_ID=your_feishu_app_id_here
FEISHU_APP_SECRET=your_feishu_app_secret_here
FEISHU_DOMAIN=feishu              # feishu（国际版）或 lark（国内版）
FEISHU_CONNECTION_MODE=websocket
FEISHU_ALLOW_ALL_USERS=false
FEISHU_ALLOWED_USERS=ou_your_user_id_here

# ── 微信配置（iLink Bot API）──
# 腾讯 iLink Bot：https://weixin.qq.com/
WEIXIN_ACCOUNT_ID=your_account_id@im.bot
WEIXIN_TOKEN=your_weixin_token_here
WEIXIN_BASE_URL=https://ilinkai.weixin.qq.com
WEIXIN_CDN_BASE_URL=https://novac2c.cdn.weixin.qq.com/c2c
WEIXIN_DM_POLICY=allowlist
WEIXIN_ALLOW_ALL_USERS=false
WEIXIN_ALLOWED_USERS=your_wechat_user_id@im.wechat
WEIXIN_GROUP_POLICY=disabled

# ── 可选：搜索工具 ──
# Tavily（AI 搜索）
TAVILY_API_KEY=your_tavily_api_key_here

# ── 可选：GitHub ──
# GITHUB_TOKEN=your_github_pat_here

# ── 调试 ──
WEB_TOOLS_DEBUG=false
VISION_TOOLS_DEBUG=false
